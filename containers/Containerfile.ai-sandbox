FROM ubuntu:24.04

ENV DEBIAN_FRONTEND=noninteractive

# System dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    git \
    openssh-client \
    zsh \
    build-essential \
    unzip \
    ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# Node.js 24.x LTS (for Claude Code, Gemini CLI, etc.)
RUN curl -fsSL https://deb.nodesource.com/setup_24.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

# Python (for Python-based AI tools)
RUN apt-get update && apt-get install -y --no-install-recommends python3 python3-pip \
    && rm -rf /var/lib/apt/lists/*

# Non-root user (create before user-scoped installs)
RUN useradd -m -s /bin/zsh developer
USER developer
ENV PATH="/home/developer/.local/bin:$PATH"

# uv (Python package manager — installs to ~/.local/bin as developer)
RUN curl -LsSf https://astral.sh/uv/install.sh | sh

# Claude Code CLI (native installer — auto-updates, no npm dependency)
RUN curl -fsSL https://claude.ai/install.sh | bash
WORKDIR /workspace

ENTRYPOINT ["/bin/zsh", "-c"]
