#!/bin/bash
set -euo pipefail

echo "=== Dotfiles bootstrap ==="
echo "Environment: {{ .environment }}"

# Detect platform
IS_WSL=false
IS_AURORA=false
IS_DISTROBOX=false

if grep -qi microsoft /proc/version 2>/dev/null; then
    IS_WSL=true
fi
if grep -qi aurora /etc/os-release 2>/dev/null; then
    IS_AURORA=true
fi
if [ -n "${DISTROBOX_ENTER_PATH:-}" ]; then
    IS_DISTROBOX=true
fi

echo "Platform: WSL=$IS_WSL, Aurora=$IS_AURORA, Distrobox=$IS_DISTROBOX"

# ─── Claude Code: replace old symlinks with chezmoi-managed files ────

for f in CLAUDE.md settings.json hooks agents skills; do
    if [ -L "$HOME/.claude/$f" ]; then
        echo "Removing old symlink: ~/.claude/$f"
        rm "$HOME/.claude/$f"
    fi
done

# ─── Core tools ──────────────────────────────────────────────────────

# Zsh
if ! command -v zsh &>/dev/null; then
    if [ "$IS_AURORA" = false ]; then
        echo "Installing zsh..."
        sudo apt-get update -qq && sudo apt-get install -y -qq zsh
    else
        echo "WARNING: zsh not found on Aurora — install via 'brew install zsh'"
    fi
fi

# Set zsh as default shell (skip on Aurora — use Ptyxis custom command instead)
if [ "$IS_AURORA" = false ] && [ "$SHELL" != "$(command -v zsh)" ]; then
    echo "Setting zsh as default shell..."
    sudo chsh -s "$(command -v zsh)" "$(whoami)"
fi

# Starship
if ! command -v starship &>/dev/null; then
    echo "Installing starship..."
    curl -sS https://starship.rs/install.sh | sh -s -- -y
fi

# JetBrainsMono Nerd Font (for Starship icons)
# On WSL, fonts render on the Windows side — install manually there
if [ "$IS_WSL" = false ]; then
    FONT_DIR="$HOME/.local/share/fonts"
    if [ ! -f "$FONT_DIR/JetBrainsMonoNerdFont-Regular.ttf" ]; then
        echo "Installing JetBrainsMono Nerd Font..."
        FONT_VERSION="3.3.0"
        mkdir -p "$FONT_DIR"
        curl -fsSL "https://github.com/ryanoasis/nerd-fonts/releases/download/v${FONT_VERSION}/JetBrainsMono.tar.xz" | tar xJ -C "$FONT_DIR"
        fc-cache -f "$FONT_DIR"
    fi
fi

# Atuin
{{ if ne .atuin_account "none" -}}
if ! command -v atuin &>/dev/null; then
    echo "Installing atuin..."
    curl -sSf https://setup.atuin.sh | bash
fi
{{ end -}}

# FZF (Aurora has system FZF via RPM — skip git install)
if [ "$IS_AURORA" = false ] && [ ! -d "$HOME/.fzf" ]; then
    echo "Installing fzf..."
    git clone --depth 1 https://github.com/junegunn/fzf.git "$HOME/.fzf"
    "$HOME/.fzf/install" --key-bindings --completion --no-update-rc --no-bash --no-fish
fi

# xclip (for pbcopy/pbpaste aliases on WSL — not needed on Aurora or Distrobox)
if ! command -v xclip &>/dev/null && [ "$IS_AURORA" = false ] && [ "$IS_DISTROBOX" = false ]; then
    echo "Installing xclip..."
    sudo apt-get install -y -qq xclip
fi

# ─── Environment-specific tools ──────────────────────────────────────

{{ if or (eq .environment "wsl-work") (eq .environment "wsl-gaming") -}}
# NVM (WSL only)
if [ ! -d "$HOME/.nvm" ]; then
    echo "Installing nvm..."
    curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.40.1/install.sh | bash
fi

# Bun (WSL only)
if ! command -v bun &>/dev/null; then
    echo "Installing bun..."
    curl -fsSL https://bun.sh/install | bash
fi
{{ end -}}

{{ if or (eq .environment "distrobox-work") (eq .environment "wsl-work") (eq .environment "wsl-gaming") -}}
# Terraform
if ! command -v terraform &>/dev/null && [ "$IS_DISTROBOX" = true ]; then
    echo "Installing terraform..."
    sudo apt-get install -y -qq gnupg software-properties-common
    curl -fsSL https://apt.releases.hashicorp.com/gpg | sudo gpg --dearmor -o /usr/share/keyrings/hashicorp-archive-keyring.gpg
    echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | sudo tee /etc/apt/sources.list.d/hashicorp.list
    sudo apt-get update -qq && sudo apt-get install -y -qq terraform
fi
{{ end -}}

{{ if or (eq .environment "distrobox-personal") -}}
# glab CLI
if ! command -v glab &>/dev/null; then
    echo "Installing glab..."
    curl -sL "https://gitlab.com/gitlab-org/cli/-/releases/permalink/latest/downloads/glab_$(uname -s)_$(uname -m).tar.gz" | tar xz -C /tmp
    sudo mv /tmp/bin/glab /usr/local/bin/
fi

# Ansible
if ! command -v ansible &>/dev/null; then
    echo "Installing ansible..."
    sudo apt-get install -y -qq ansible
fi
{{ end -}}

# ─── Credential directories ──────────────────────────────────────────

{{ if .has_work_creds -}}
mkdir -p ~/.aws ~/.kube
{{ end -}}

{{ if .has_homelab_creds -}}
mkdir -p ~/.kube
{{ end -}}

mkdir -p ~/.ssh
chmod 700 ~/.ssh

# ─── Post-install instructions ───────────────────────────────────────

echo ""
echo "=== Bootstrap complete ==="
echo ""
if [ "$IS_WSL" = true ]; then
    echo "Font setup (WSL only — one time):"
    echo "  Download JetBrainsMono Nerd Font from: https://www.nerdfonts.com/font-downloads"
    echo "  Extract, select all .ttf files, right-click → Install"
    echo "  Then set 'JetBrainsMono Nerd Font' as the font in Windows Terminal settings"
    echo ""
fi
echo "Credential setup (do these once):"
echo "  1. SSH keys:     Copy .pub files to ~/.ssh/ (chmod 644)"
echo "                   Private keys stay in 1Password — SSH agent serves them"
{{ if .has_work_creds -}}
echo "  2. AWS:          aws sso login --profile <name>"
{{ end -}}
{{ if .has_homelab_creds -}}
echo "  3. Kubeconfig:   Copy homelab.yaml → ~/.kube/"
echo "  4. GitLab:       glab auth login --hostname gitlab.k8s.rommelporras.com"
{{ end -}}
echo "  5. GitHub:       gh auth login"
{{ if ne .atuin_account "none" -}}
echo "  6. Atuin:        atuin login -u {{ .atuin_account }}"
{{ end -}}
if [ "$IS_AURORA" = true ]; then
    echo ""
    echo "Aurora-specific setup:"
    echo "  - Shell: In Ptyxis, edit the default profile → Custom Command → /home/linuxbrew/.linuxbrew/bin/zsh"
    echo "  - DO NOT use chsh — atomic systems don't have it"
    echo "  - 1Password: rpm-ostree install 1password 1password-cli && reboot"
    echo "  - Enable SSH Agent in 1Password → Settings → Developer"
fi
echo ""
echo "Restart your shell or run: exec zsh"
