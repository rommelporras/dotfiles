{{- $environment := promptStringOnce . "environment" "Environment (wsl-work/wsl-gaming/aurora/distrobox-work/distrobox-personal/distrobox-sandbox)" -}}

{{/* Smart defaults — only prompt for what's relevant to this environment */}}
{{- $personalEmail := "" -}}
{{- $workEmail := "" -}}
{{- $hasWorkCreds := false -}}
{{- $hasHomelabCreds := false -}}
{{- $atuinSyncAddress := "" -}}
{{- $atuinAccount := "none" -}}

{{- if or (eq $environment "aurora") (eq $environment "wsl-work") (eq $environment "wsl-gaming") (eq $environment "distrobox-personal") -}}
{{-   $personalEmail = promptStringOnce . "personal_email" "Personal git email (e.g. you@example.com)" -}}
{{- end -}}

{{- if or (eq $environment "wsl-work") (eq $environment "wsl-gaming") (eq $environment "distrobox-work") -}}
{{-   $workEmail = promptStringOnce . "work_email" "Work git email (e.g. you@company.com)" -}}
{{- end -}}

{{- if or (eq $environment "wsl-work") (eq $environment "wsl-gaming") (eq $environment "distrobox-work") -}}
{{-   $hasWorkCreds = promptBoolOnce . "has_work_creds" "Work credentials — AWS, EKS? (y/N)" -}}
{{- end -}}

{{- if or (eq $environment "aurora") (eq $environment "wsl-work") (eq $environment "wsl-gaming") (eq $environment "distrobox-personal") -}}
{{-   $hasHomelabCreds = promptBoolOnce . "has_homelab_creds" "Homelab credentials? (y/N)" -}}
{{- end -}}

{{- if ne $environment "distrobox-sandbox" -}}
{{-   $atuinSyncAddress = promptStringOnce . "atuin_sync_address" "Atuin sync server URL (e.g. https://atuin.k8s.rommelporras.com, blank to skip)" -}}
{{-   $atuinAccount = promptStringOnce . "atuin_account" "Atuin account (rommel-personal/rommel-work/none)" -}}
{{- end -}}

[data]
  environment = {{ $environment | quote }}
  personal_email = {{ $personalEmail | quote }}
  work_email = {{ $workEmail | quote }}
  has_work_creds = {{ $hasWorkCreds }}
  has_homelab_creds = {{ $hasHomelabCreds }}
  atuin_sync_address = {{ $atuinSyncAddress | quote }}
  atuin_account = {{ $atuinAccount | quote }}
