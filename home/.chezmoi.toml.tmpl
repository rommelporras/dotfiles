{{/* Auto-detect platform — never prompted */}}
{{- $platform := "unknown" -}}
{{- if env "DISTROBOX_ENTER_PATH" -}}
{{-   $platform = "distrobox" -}}
{{- else if and (stat "/etc/os-release") (contains "aurora" (lower (include "/etc/os-release"))) -}}
{{-   $platform = "aurora" -}}
{{- else if and (stat "/proc/version") (contains "microsoft" (lower (include "/proc/version"))) -}}
{{-   $platform = "wsl" -}}
{{- end -}}

{{- $context := promptStringOnce . "context" "Context (personal/personal-<project>/work-eam/work-<name>/gaming/sandbox)" -}}

{{/* Smart defaults — only prompt for what's relevant */}}
{{- $personalEmail := "" -}}
{{- $workEmail := "" -}}
{{- $hasWorkCreds := false -}}
{{- $hasHomelabCreds := false -}}
{{- $atuinSyncAddress := "" -}}
{{- $atuinAccount := "none" -}}

{{- if and (ne $context "sandbox") (or (not (hasPrefix "work-" $context)) (eq $platform "wsl")) -}}
{{-   $personalEmail = promptStringOnce . "personal_email" "Personal git email (e.g. you@example.com)" -}}
{{- end -}}

{{- if hasPrefix "work-" $context -}}
{{-   $workEmail = promptStringOnce . "work_email" "Work git email (e.g. you@company.com)" -}}
{{- end -}}

{{- if hasPrefix "work-" $context -}}
{{-   $hasWorkCreds = promptBoolOnce . "has_work_creds" "Work credentials — AWS, EKS? (y/N)" -}}
{{- end -}}

{{- if or (eq $context "personal") (eq $context "gaming") (eq $platform "aurora") -}}
{{-   $hasHomelabCreds = promptBoolOnce . "has_homelab_creds" "Homelab credentials? (y/N)" -}}
{{- end -}}

{{- if ne $context "sandbox" -}}
{{-   $atuinSyncAddress = promptStringOnce . "atuin_sync_address" "Atuin sync server URL (e.g. https://atuin.k8s.rommelporras.com, blank to skip)" -}}
{{-   $atuinAccount = promptStringOnce . "atuin_account" "Atuin account (rommel-personal/work-eam/work-<name>/none)" -}}
{{- end -}}

{{/* Derived: personal-<project> containers get native op CLI instead of distrobox-host-exec */}}
{{- $hasOpCli := and (hasPrefix "personal-" $context) (eq $platform "distrobox") -}}

[data]
  platform = {{ $platform | quote }}
  context = {{ $context | quote }}
  personal_email = {{ $personalEmail | quote }}
  work_email = {{ $workEmail | quote }}
  has_work_creds = {{ $hasWorkCreds }}
  has_homelab_creds = {{ $hasHomelabCreds }}
  has_op_cli = {{ $hasOpCli }}
  atuin_sync_address = {{ $atuinSyncAddress | quote }}
  atuin_account = {{ $atuinAccount | quote }}
