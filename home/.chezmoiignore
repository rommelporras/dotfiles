# README and repo meta files are not dotfiles
README.md
LICENSE
docs/

# OMZ generates these at runtime
.oh-my-zsh/cache/

# Skip glab config if no homelab credentials and not personal-<project>
{{- if and (not .has_homelab_creds) (not (hasPrefix "personal-" .context)) }}
.config/glab-cli/
{{- end }}

# Skip AWS config if no work credentials
{{- if not .has_work_creds }}
.aws/
{{- end }}

# Claude Code config is managed by claude-config repo (symlinks), not chezmoi
.claude/

# personal-<project>: no kubeconfig (no homelab access)
{{- if hasPrefix "personal-" .context }}
.kube/
{{- end }}

# Sandbox: no credential seeding
{{- if eq .context "sandbox" }}
.local/bin/setup-creds
{{- end }}
