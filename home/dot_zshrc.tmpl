# Ensure $SHELL matches the running shell (distrobox inherits host's $SHELL)
export SHELL=$(command -v zsh)
{{ if eq .platform "distrobox" -}}
# Start in container home if CWD was inherited from host (Ptyxis passthrough)
[[ "$PWD" != "$HOME"* ]] && cd
{{ end -}}

# Path
export PATH="$HOME/.local/bin:$PATH"

# History
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""  # Disabled — Starship handles the prompt

plugins=(
    1password
    aws
    docker
    docker-compose
    gh
    git
    git-commit
    gitfast
    github
    helm
    history
    kubectl
    kubectx
    last-working-dir
    node
    npm
    nvm
    pip
    pod
    python
    safe-paste
    ssh
    sudo
    systemd
    terraform
    vscode
    zsh-interactive-cd
    zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# Starship prompt (Aurora: system /etc/zsh/zshrc already inits starship)
{{ if ne .platform "aurora" -}}
command -v starship &>/dev/null && eval "$(starship init zsh)"
{{ end -}}

# Atuin shell history
{{ if ne .atuin_account "none" -}}
[ -f "$HOME/.atuin/bin/env" ] && . "$HOME/.atuin/bin/env"
command -v atuin &>/dev/null && eval "$(atuin init zsh)"
{{ end -}}

# FZF (Aurora has system FZF at /usr/share/fzf/shell/, others use git install)
{{ if eq .platform "aurora" -}}
[ -f /usr/share/fzf/shell/key-bindings.zsh ] && source /usr/share/fzf/shell/key-bindings.zsh
{{ else -}}
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
{{ end -}}

{{ if eq .platform "wsl" -}}
# 1Password SSH Agent bridge (WSL → Windows named pipe via npiperelay)
export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
if ! ps aux | grep -q "[n]piperelay.exe -ei -s //./pipe/openssh-ssh-agent"; then
    mkdir -p "$HOME/.1password"
    [ -S "$SSH_AUTH_SOCK" ] && rm "$SSH_AUTH_SOCK"
    (setsid socat UNIX-LISTEN:"$SSH_AUTH_SOCK",fork EXEC:"npiperelay.exe -ei -s //./pipe/openssh-ssh-agent",nofork &) >/dev/null 2>&1
fi
{{ else if eq .platform "aurora" -}}
# 1Password SSH Agent (native Linux — socket created by 1Password app)
export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
{{ else -}}
# 1Password SSH Agent (host socket — $HOME differs inside distrobox, use absolute path)
export SSH_AUTH_SOCK="/home/{{ .chezmoi.username }}/.1password/agent.sock"
{{ end -}}

{{ if eq .platform "distrobox" -}}
# ─── IDE forwarding (host apps via distrobox-host-exec) ─────────────
# VS Code and Antigravity run on the Aurora host; these wrappers
# forward commands so 'code .', 'agy', and 'antigravity' work transparently.
if command -v distrobox-host-exec &>/dev/null; then
    alias code='distrobox-host-exec code'
    alias antigravity='distrobox-host-exec antigravity'
    alias agy='distrobox-host-exec antigravity'
fi
# BROWSER — forward xdg-open to host so OAuth flows and link-opening work
export BROWSER="distrobox-host-exec xdg-open"
{{ end -}}

# ─── Auto-sync claude-config on shell startup ────────────────────────
# Distrobox: not needed — containers use host repo via absolute symlink.
# Aurora/WSL: pull in background using HTTPS (public repo, no SSH agent needed).
{{ if ne .platform "distrobox" -}}
if [ -d "$HOME/personal/claude-config" ]; then
    (GIT_TERMINAL_PROMPT=0 timeout 5 git -C "$HOME/personal/claude-config" pull --ff-only --quiet >/dev/null 2>&1 &)
fi
{{ end -}}

# ─── Source bling.sh on Aurora (eza, bat, direnv, zoxide, mise, ugrep) ──
{{ if eq .platform "aurora" -}}
test -f /usr/share/ublue-os/bling/bling.sh && source /usr/share/ublue-os/bling/bling.sh
{{ end -}}

# ─── Universal aliases ───────────────────────────────────────────────
{{ if ne .platform "aurora" -}}
alias ll="ls -ltra"
{{ end -}}
alias gd="git diff"
alias gcmsg="git commit -m"
alias gitc="git checkout"
alias gitm="git checkout main"
{{ if eq .platform "aurora" -}}
alias agy='antigravity'
{{ end -}}
alias zshconfig="${EDITOR:-code} ~/.zshrc"
alias pip=pip3
alias ai-sandbox="$HOME/personal/dotfiles/bin/ai-sandbox"

{{ if eq .platform "wsl" -}}
# ─── WSL-only ────────────────────────────────────────────────────────
alias pbcopy='xclip -selection clipboard'
alias pbpaste='xclip -selection clipboard -o'
export BROWSER="/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"
export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"

# Runtime managers
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"
{{ end -}}

{{ if eq .platform "distrobox" -}}
# NVM (distrobox — nvm installs to $HOME/.config/nvm or $HOME/.nvm)
export NVM_DIR="${NVM_DIR:-$HOME/.config/nvm}"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
{{ end -}}

{{ if and (hasPrefix "personal-" .context) (eq .platform "distrobox") -}}
# Bun (personal-<project> distrobox)
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"
{{ end -}}

{{ if hasPrefix "personal-" .context -}}
# 1Password biometric unlock (personal-<project> — native op CLI)
export OP_BIOMETRIC_UNLOCK_ENABLED=true
{{ end -}}

{{ if hasPrefix "work-" .context -}}
# ─── Shared work tools ───────────────────────────────────────────────
alias tfi="terraform init -reconfigure"
alias tfp="terraform plan"
alias tfwl="terraform workspace list"
{{ end -}}

{{ if eq .context "work-eam" -}}
# ─── EAM-specific ────────────────────────────────────────────────────
alias eam='cd ~/eam'
alias eam-sre='cd ~/eam/eam-sre/rommel-porras'
alias eam-terraform='cd ~/eam/eam-terraform'
alias nightly-restart='cd ~/eam/eam-nightly-restart'
alias tmp='cd ~/eam/tmp'
{{ end -}}

{{ if or (eq .context "personal") (hasPrefix "personal-" .context) -}}
# ─── Personal context ────────────────────────────────────────────────
alias personal='cd ~/personal'
{{ end -}}

{{ if or (eq .context "personal") (hasPrefix "personal-" .context) (hasPrefix "work-" .context) -}}
# Claude Code Telemetry → Homelab K8s OTel Collector
export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://10.10.30.22:4317
export OTEL_METRIC_EXPORT_INTERVAL=5000
export OTEL_LOGS_EXPORT_INTERVAL=5000
export OTEL_RESOURCE_ATTRIBUTES="machine.name=$HOST"
{{ end -}}

{{ if eq .context "personal" -}}
# ─── Homelab context ─────────────────────────────────────────────────
alias invoicetron='cd ~/personal/invoicetron'
alias homelab='cd ~/personal/homelab'
alias kubectl-homelab='kubectl --kubeconfig ~/.kube/homelab-claude.yaml'
alias kubectl-admin='kubectl --kubeconfig ~/.kube/homelab.yaml'
alias helm-homelab='KUBECONFIG=~/.kube/homelab.yaml helm'
export VAULT_ADDR=https://vault.k8s.rommelporras.com
{{ end -}}
