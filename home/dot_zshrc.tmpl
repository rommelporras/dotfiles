# Path
export PATH="$HOME/.local/bin:$PATH"

# History
HISTFILE=~/.zsh_history
HISTSIZE=50000
SAVEHIST=50000

# Oh My Zsh
export ZSH="$HOME/.oh-my-zsh"
ZSH_THEME=""  # Disabled — Starship handles the prompt

plugins=(
    1password
    aws
    docker
    docker-compose
    gh
    git
    git-commit
    gitfast
    github
    helm
    history
    kubectl
    kubectx
    last-working-dir
    node
    npm
    nvm
    pip
    pipenv
    pod
    pylint
    python
    safe-paste
    ssh
    sudo
    systemd
    tailscale
    terraform
    vscode
    zsh-interactive-cd
    zsh-navigation-tools
    zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# Starship prompt (Aurora: system /etc/zsh/zshrc already inits starship)
{{ if ne .environment "aurora" -}}
command -v starship &>/dev/null && eval "$(starship init zsh)"
{{ end -}}

# Atuin shell history
{{ if ne .atuin_account "none" -}}
[ -f "$HOME/.atuin/bin/env" ] && . "$HOME/.atuin/bin/env"
command -v atuin &>/dev/null && eval "$(atuin init zsh)"
{{ end -}}

# FZF (Aurora has system FZF at /usr/share/fzf/shell/, others use git install)
{{ if eq .environment "aurora" -}}
[ -f /usr/share/fzf/shell/key-bindings.zsh ] && source /usr/share/fzf/shell/key-bindings.zsh
{{ else -}}
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh
{{ end -}}

{{ if or (eq .environment "wsl-work") (eq .environment "wsl-gaming") -}}
# 1Password SSH Agent bridge (WSL → Windows named pipe via npiperelay)
export SSH_AUTH_SOCK="$HOME/.1password/agent.sock"
if ! ps aux | grep -q "[n]piperelay.exe -ei -s //./pipe/openssh-ssh-agent"; then
    mkdir -p "$HOME/.1password"
    [ -S "$SSH_AUTH_SOCK" ] && rm "$SSH_AUTH_SOCK"
    (setsid socat UNIX-LISTEN:"$SSH_AUTH_SOCK",fork EXEC:"npiperelay.exe -ei -s //./pipe/openssh-ssh-agent",nofork &) >/dev/null 2>&1
fi
{{ else if eq .environment "aurora" -}}
# 1Password SSH Agent (native Linux — socket created by 1Password app)
export SSH_AUTH_SOCK="$HOME/.1Password/agent.sock"
{{ else -}}
# SSH agent fallback (distrobox inherits host agent, or starts its own)
if [ -z "$SSH_AUTH_SOCK" ]; then
    eval "$(ssh-agent -s)" > /dev/null
fi
{{ end -}}

# ─── Source bling.sh on Aurora (eza, bat, direnv, zoxide, mise, ugrep) ──
{{ if eq .environment "aurora" -}}
test -f /usr/share/ublue-os/bling/bling.sh && source /usr/share/ublue-os/bling/bling.sh
{{ end -}}

# ─── Universal aliases ───────────────────────────────────────────────
{{ if ne .environment "aurora" -}}
alias ll="ls -ltra"
{{ end -}}
alias gd="git diff"
alias gcmsg="git commit -m"
alias gitc="git checkout"
alias gitm="git checkout master"
alias zshconfig="${EDITOR:-code} ~/.zshrc"
alias pip=pip3

{{ if or (eq .environment "wsl-work") (eq .environment "wsl-gaming") -}}
# ─── WSL-only ────────────────────────────────────────────────────────
alias pbcopy='xclip -selection clipboard'
alias pbpaste='xclip -selection clipboard -o'
export BROWSER="/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"
export PLAYWRIGHT_CHROMIUM_EXECUTABLE_PATH="/mnt/c/Program Files/Google/Chrome/Application/chrome.exe"

# Runtime managers
export NVM_DIR="$HOME/.nvm"
[ -s "$NVM_DIR/nvm.sh" ] && \. "$NVM_DIR/nvm.sh"
[ -s "$NVM_DIR/bash_completion" ] && \. "$NVM_DIR/bash_completion"
export BUN_INSTALL="$HOME/.bun"
export PATH="$BUN_INSTALL/bin:$PATH"
[ -s "$BUN_INSTALL/_bun" ] && source "$BUN_INSTALL/_bun"
{{ end -}}

{{ if or (eq .environment "wsl-work") (eq .environment "wsl-gaming") (eq .environment "distrobox-work") -}}
# ─── Work context ────────────────────────────────────────────────────
alias tfi="terraform init -reconfigure"
alias tfp="terraform plan"
alias tfwl="terraform workspace list"
alias eam='cd ~/eam'
alias eam-sre='cd ~/eam/eam-sre/rommel-porras'
alias eam-terraform='cd ~/eam/eam-terraform'
alias nightly-restart='cd ~/eam/eam-nightly-restart'
alias tmp='cd ~/eam/tmp'
{{ end -}}

{{ if or (eq .environment "wsl-work") (eq .environment "wsl-gaming") (eq .environment "aurora") (eq .environment "distrobox-personal") -}}
# ─── Personal/homelab context ────────────────────────────────────────
alias personal='cd ~/personal'
alias invoicetron='cd ~/personal/invoicetron'
alias homelab='cd ~/personal/homelab'
alias kubectl-homelab='kubectl --kubeconfig ~/.kube/homelab.yaml'
alias helm-homelab='KUBECONFIG=~/.kube/homelab.yaml helm'

# Claude Code Telemetry → Homelab K8s OTel Collector
export CLAUDE_CODE_ENABLE_TELEMETRY=1
export OTEL_METRICS_EXPORTER=otlp
export OTEL_LOGS_EXPORTER=otlp
export OTEL_EXPORTER_OTLP_PROTOCOL=grpc
export OTEL_EXPORTER_OTLP_ENDPOINT=http://10.10.30.22:4317
export OTEL_METRIC_EXPORT_INTERVAL=5000
export OTEL_LOGS_EXPORT_INTERVAL=5000
export OTEL_RESOURCE_ATTRIBUTES="machine.name=$HOST"
{{ end -}}
